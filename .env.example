AIRFLOW_HOME=$HOME/repos/cinemattr-db/db/airflow
AIRFLOW_CONFIG=$AIRFLOW_HOME/airflow.cfg
DBT_PROFILES_DIR=$HOME/repos/cinemattr-db/db/dbt/.dbt
SCRAPINGANT_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# LLM provider config (OpenAI-compatible)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
LLM_MODEL=gpt-4.1-mini
OPENAI_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Embeddings provider config (falls back to LLM_* if omitted)
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
# Required. Must match the embedding model's output dim (e.g. 1536 for text-embedding-3-small,
# 768/1536/3072 for gemini-embedding-001 via Matryoshka).
EMBEDDING_DIM=1536

# DuckDB VSS (vector store)
DUCKDB_PATH=data/cinemattr.duckdb
VSS_TABLE=movie_embeddings
VECTOR_TOP_K=20

# API hardening
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
ALLOWED_ORIGINS=*
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_IPS=
