AIRFLOW_HOME=$HOME/repos/cinemattr-db/db/airflow
AIRFLOW_CONFIG=$AIRFLOW_HOME/airflow.cfg
DBT_PROFILES_DIR=$HOME/repos/cinemattr-db/db/dbt/.dbt
SCRAPINGANT_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# LLM provider config (OpenAI-compatible)
# Use OPENAI_API_KEY if you are on OpenAI directly.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
LLM_MODEL=gpt-4.1-mini
OPENAI_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Embeddings provider config (falls back to LLM_* values if omitted)
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
HF_EMBEDDING_DEVICE=

# Vector search config
COHERE_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PINECONE_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PINECONE_ENV=northamerica-northeast1-gcp
PINECONE_INDEX_NAME=cinemattr
VECTOR_INDEX_NAME=cinemattr
VECTOR_TOP_K=20

# API hardening
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
ALLOWED_ORIGINS=*
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_IPS=

# Optional local cache path
LANGCHAIN_CACHE_PATH=/tmp/langchain.db

TRANSFORMERS_CACHE=/tmp
SENTENCE_TRANSFORMERS_HOME=/tmp
XDG_CACHE_HOME=/tmp
HF_HOME=/tmp
LAMBDA_ECR_REPO=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
